@{
    ViewData["Title"] = "Página Principal";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="fw-semibold">Sistema de Gestão de Carros</h1>
        <p class="text-muted">Gerencie carros e fabricantes de forma prática</p>
    </div>

    <div class="row justify-content-center g-4">

        <!-- FABRICANTES -->
        <div class="col-md-4">
            <div class="card custom-card text-center">
                <div class="card-body">
                    <h5 class="card-title mb-3">Fabricantes</h5>
                    <p class="card-text text-muted">
                        Gerencie informações dos fabricantes cadastrados.
                    </p>
                    <a href="/Fabricantes" class="btn btn-custom w-100">Acessar</a>
                </div>
            </div>
        </div>

        <!-- CARROS -->
        <div class="col-md-4">
            <div class="card custom-card text-center">
                <div class="card-body">
                    <h5 class="card-title mb-3">Carros</h5>
                    <p class="card-text text-muted">
                        Gerencie os carros disponíveis no sistema.
                    </p>
                    <a href="/Carros" class="btn btn-custom w-100">Acessar</a>
                </div>
            </div>
        </div>

    </div>
</div>